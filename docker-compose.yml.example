version: '3.8'

services:
  cosplay-panel:
    build: .
    container_name: cosplay-panel
    ports:
      - "8501:8501" # 左侧可修改为宿主机想用的端口
    volumes:
      # 1. 映射 i18n JSON文件和缓存 CSV 的目录
      # 左侧(宿主机): 在当前目录下创建一个 app_data 文件夹来存这些文件
      # 右侧(容器内): 必须为 /app/data，与代码中配置的环境变量对应
      - ./app_data:/app/data
      
      # 2. 映射 NAS 上的真实图包目录 (只读映射 :ro 以确保不会误删图片)
      # 左侧(宿主机): 请替换为你 NAS 存放所有 Coser 图包的绝对路径! 例如 /volume1/Media/Cosplay
      # 右侧(容器内): /app/cosplay_data
      - /path/to/your/nas/cosplay:/app/cosplay_data:ro
    environment:
      # 告诉 Python 代码从哪里读取挂载进来的目录
      - NAS_BASE_PATH=/app/cosplay_data
      - DATA_DIR=/app/data
      - STREAMLIT_SERVER_MAX_MESSAGE_SIZE=200 # 防止前端渲染百万级数据时断开
    restart: unless-stopped